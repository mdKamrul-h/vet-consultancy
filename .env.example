# ============================================================
# Pawpet - Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ============================================================

# ── Database ────────────────────────────────────────────────
POSTGRES_DB=pawpet
POSTGRES_USER=pawpet
POSTGRES_PASSWORD=pawpet123

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=pawpet-super-secret-jwt-key-2024
JWT_EXPIRES_IN=7d

# ── Jitsi Meet ──────────────────────────────────────────────
JITSI_APP_ID=pawpet
JITSI_SECRET=jitsi-secret-key

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
