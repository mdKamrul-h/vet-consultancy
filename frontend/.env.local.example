# ── Local development (direct backend) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_JITSI_DOMAIN=localhost:8080

# ── Vercel production (set these in the Vercel dashboard) ─────────────────────
# Option A: proxy API through Next.js rewrites (recommended — avoids CORS)
# NEXT_PUBLIC_API_URL=/api
# BACKEND_URL=https://your-backend.example.com
# NEXT_PUBLIC_SOCKET_URL=https://your-backend.example.com
# NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
#
# Option B: call the backend API directly (set CORS_ORIGIN on the backend)
# NEXT_PUBLIC_API_URL=https://your-backend.example.com/api
# NEXT_PUBLIC_SOCKET_URL=https://your-backend.example.com
# NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
